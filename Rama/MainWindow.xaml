<Window x:Class="Rama.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rama — AI Assistant" 
        Height="750" Width="1100"
        MinHeight="550" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- User Chat Bubble -->
        <Style x:Key="ChatBubbleUser" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#89B4FA" Offset="0"/>
                        <GradientStop Color="#74C7EC" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="18,18,4,18"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="80,6,16,6"/>
            <Setter Property="MaxWidth" Value="550"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- Bot Chat Bubble -->
        <Style x:Key="ChatBubbleBot" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BotBubbleBrush}"/>
            <Setter Property="CornerRadius" Value="18,18,18,4"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="16,6,80,6"/>
            <Setter Property="MaxWidth" Value="550"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- Skill Card -->
        <Style x:Key="SkillCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Typing Indicator -->
        <Style x:Key="TypingIndicator" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BotBubbleBrush}"/>
            <Setter Property="CornerRadius" Value="18,18,18,4"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="16,6,80,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <!-- Main Container -->
    <Border CornerRadius="12" Background="{StaticResource BackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="🤖" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="  RAMA" FontSize="14" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="  AI Assistant" FontSize="11" 
                                   Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button Content="─" Width="36" Height="30" FontSize="14"
                                Background="Transparent" Foreground="{StaticResource SubTextBrush}"
                                Click="Minimize_Click" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="□" Width="36" Height="30" FontSize="12"
                                Background="Transparent" Foreground="{StaticResource SubTextBrush}"
                                Click="Maximize_Click" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✕" Width="36" Height="30" FontSize="12"
                                Background="Transparent" Foreground="#F38BA8"
                                Click="Close_Click" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#45475A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ SIDEBAR ═══ -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" 
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Logo -->
                        <StackPanel DockPanel.Dock="Top" Margin="20,20,20,12">
                            <Border Background="{StaticResource CardBrush}" CornerRadius="16" 
                                    Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <TextBlock Text="🧠" FontSize="28" HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Rama" FontSize="22" FontWeight="Bold" 
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Self-Learning AI Assistant" FontSize="10.5" 
                                       Foreground="{StaticResource SubTextBrush}" HorizontalAlignment="Center" 
                                       Margin="0,2,0,0"/>

                            <!-- Voice Toggle -->
                            <Border x:Name="VoiceToggle" Background="{StaticResource CardBrush}" 
                                    CornerRadius="20" Padding="12,6" Margin="0,12,0,0"
                                    HorizontalAlignment="Center" Cursor="Hand"
                                    MouseLeftButtonDown="VoiceToggle_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="VoiceIcon" Text="🎤" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="VoiceLabel" Text=" Voice Off" FontSize="11" 
                                               Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Stats -->
                        <Border DockPanel.Dock="Bottom" Background="{StaticResource CardBrush}" 
                                CornerRadius="12" Margin="12,0,12,8" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="📊 Learning Stats" FontWeight="SemiBold" FontSize="12" 
                                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="StatInteractions" Text="0" FontSize="18" 
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="Chats" FontSize="10" 
                                                   Foreground="{StaticResource SubTextBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="StatPatterns" Text="0" FontSize="18" 
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="Patterns" FontSize="10" 
                                                   Foreground="{StaticResource SubTextBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="4" 
                                        Margin="0,8,0,0" Padding="8,4">
                                    <TextBlock x:Name="StatTopSkill" Text="Start chatting!" FontSize="10" 
                                               Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Skills -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4,0">
                            <StackPanel x:Name="SkillsPanel">
                                <TextBlock Text="⚡ SKILLS" FontWeight="Bold" FontSize="11" 
                                           Foreground="{StaticResource SubTextBrush}" Margin="12,8,0,6"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ═══ CHAT AREA ═══ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Messages -->
                    <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="0" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ChatPanel" Margin="0,8,0,16">
                            <!-- Welcome -->
                            <Border Style="{StaticResource ChatBubbleBot}">
                                <StackPanel MaxWidth="480">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="🤖" FontSize="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="  Rama" FontSize="13" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,4">
                                        Hey! I'm <Bold>Rama</Bold> — your self-learning AI assistant. And yes, I have opinions. 😏
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource SubTextBrush}" 
                                               Margin="0,4,0,8" LineHeight="20">
                                        I can launch apps, search the web, take notes, set reminders, check weather, do math, and more. Plus I learn from every chat!
                                    </TextBlock>
                                    <WrapPanel Margin="0,0,0,8">
                                        <Border Background="#89B4FA" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="🚀 Launch apps" FontSize="11" Foreground="#89B4FA"/>
                                        </Border>
                                        <Border Background="#A6E3A1" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="📁 Manage files" FontSize="11" Foreground="#A6E3A1"/>
                                        </Border>
                                        <Border Background="#F9E2AF" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="🔍 Web search" FontSize="11" Foreground="#F9E2AF"/>
                                        </Border>
                                        <Border Background="#CBA6F7" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="📝 Take notes" FontSize="11" Foreground="#CBA6F7"/>
                                        </Border>
                                        <Border Background="#F38BA8" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="⏰ Set reminders" FontSize="11" Foreground="#F38BA8"/>
                                        </Border>
                                        <Border Background="#89DCEB" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="🧮 Calculator" FontSize="11" Foreground="#89DCEB"/>
                                        </Border>
                                        <Border Background="#FAB387" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="🌤️ Weather" FontSize="11" Foreground="#FAB387"/>
                                        </Border>
                                        <Border Background="#F5C2E7" Opacity="0.15" CornerRadius="12" 
                                                Padding="10,4" Margin="0,0,6,4" Cursor="Hand"
                                                MouseLeftButtonDown="Suggestion_Click">
                                            <TextBlock Text="🎤 Voice mode" FontSize="11" Foreground="#F5C2E7"/>
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource AccentBrush}" 
                                               Opacity="0.8">
                                        💡 Try "set sass max" for maximum attitude. Click the mic to talk to me!
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ INPUT AREA ═══ -->
                    <Border Grid.Row="1" Background="{StaticResource InputAreaBrush}" 
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" 
                            Padding="16,12">
                        <Grid>
                            <!-- Input row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Input Box -->
                                <Border Grid.Column="0" CornerRadius="24" 
                                        Background="{StaticResource InputBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <TextBox x:Name="InputBox" 
                                                 Background="Transparent" Foreground="{StaticResource TextBrush}"
                                                 BorderThickness="0" Padding="20,10,10,10" FontSize="14"
                                                 VerticalContentAlignment="Center" TextWrapping="Wrap"
                                                 AcceptsReturn="False"/>
                                        <TextBlock x:Name="PlaceholderText" Text="Ask Rama anything..."
                                                   Foreground="{StaticResource SubTextBrush}" FontSize="14"
                                                   VerticalAlignment="Center" Margin="20,0,0,0"
                                                   IsHitTestVisible="False"/>
                                        <!-- Voice partial text -->
                                        <TextBlock x:Name="VoicePartialText" Text="" 
                                                   Foreground="{StaticResource AccentBrush}" FontSize="12"
                                                   VerticalAlignment="Bottom" Margin="20,0,0,6"
                                                   IsHitTestVisible="False" Opacity="0.7"/>
                                    </Grid>
                                </Border>

                                <!-- Microphone Button -->
                                <Button x:Name="MicButton" Grid.Column="1" Width="44" Height="44"
                                        Margin="8,0,0,0" Cursor="Hand" Click="MicButton_Click"
                                        Background="{StaticResource CardBrush}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" CornerRadius="22" 
                                                    Background="{TemplateBinding Background}">
                                                <TextBlock Text="🎤" FontSize="18" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#45475A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Send Button -->
                                <Button x:Name="SendButton" Grid.Column="2" Width="44" Height="44"
                                        Margin="8,0,0,0" Cursor="Hand" Click="SendButton_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" CornerRadius="22" 
                                                    Background="{StaticResource AccentBrush}">
                                                <TextBlock Text="➤" FontSize="18" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="-45"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" 
                                                                              Color="#89B4FA" Opacity="0.5"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    Background="{StaticResource SidebarBrush}" CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,6">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#A6E3A1" 
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Ready" FontSize="11" 
                                   Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Border x:Name="VoiceStatusBadge" Background="{StaticResource CardBrush}" CornerRadius="10" 
                                Padding="10,3" Margin="8,0,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#F38BA8" Margin="0,0,4,0" 
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="LISTENING" FontSize="9" FontWeight="Bold" 
                                           Foreground="#F38BA8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10" 
                                Padding="10,3" Margin="8,0,0,0">
                            <TextBlock x:Name="SkillIndicator" Text="" FontSize="10" 
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10" 
                                Padding="10,3" Margin="8,0,0,0">
                            <TextBlock Text="v1.0" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
